# =====================================================
# USTOZ AI — .env konfiguratsiya
# =====================================================

# ── DATABASE ─────────────────────────────────────────
DATABASE_URL=postgresql://postgres:PASSWORD@localhost:5432/ustoz_yordamchi

# ── JWT ──────────────────────────────────────────────
JWT_SECRET=ustoz_jwt_secret_2026_change_this
SUPER_JWT_SECRET=boss_super_secret_change_this

# ── BOSS ADMIN ───────────────────────────────────────
SUPER_ADMIN_USER=boss_admin
SUPER_ADMIN_PASS=ustoz2026
# Yoki bcrypt hash (xavfsizroq):
# SUPER_ADMIN_PASS_HASH=$2a$10$xxxxxxxxxxxxx

# ── TO'LOVCHI.UZ API ────────────────────────────────
TOLOV_API_URL=https://tolovavto.up.railway.app/api
TOLOV_SHOP_ID=YOUR_SHOP_ID_HERE
TOLOV_SHOP_KEY=YOUR_SHOP_KEY_HERE

# ── RAILWAY APP URL ──────────────────────────────────
# Railway da deploy qilgandan keyin shu URLni kiriting
# O'quv markazlar shu URL + /center/ID formatida ochiladi
BASE_URL=https://your-app.up.railway.app

# ── EMAIL (oldingi sozlama) ──────────────────────────
REACT_APP_EMAILJS_SERVICE=your_service
REACT_APP_EMAILJS_TEMPLATE=your_template
REACT_APP_EMAILJS_KEY=your_key

# ── SERVER ───────────────────────────────────────────
PORT=5000
NODE_ENV=production
